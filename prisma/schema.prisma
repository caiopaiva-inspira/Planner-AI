generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id // Maps to Supabase auth.users.id
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events    Event[]
  tasks     Task[]
}

model Event {
  id        String   @id @default(uuid())
  title     String
  timeStart String
  timeEnd   String
  location  String?
  icon      String   @default("calendar")
  dateKey   String   // e.g., "2024-03-05"
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id        String   @id @default(uuid())
  title     String
  completed Boolean  @default(false)
  dateKey   String   // e.g., "2024-03-05"

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
